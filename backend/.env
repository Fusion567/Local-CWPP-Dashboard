# --- AWS Hub (Management) Account Credentials ---
AWS_ACCESS_KEY_ID=YOUR_HUB_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_HUB_SECRET_KEY_HERE
AWS_DEFAULT_REGION=us-east-1

# --- PostgreSQL Connection ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/cwpp_db

# Individual DB components (used as fallback)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cwpp_db
DB_USER=postgres
DB_PASSWORD=yourpassword